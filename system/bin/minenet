#!/system/bin/sh

ST_DIR="/data/local/tmp/minenet"
mkdir -p $ST_DIR

actualizar() {
    # Enviamos los comandos al sistema, pero tiramos los errores a la basura
    am broadcast -a com.android.systemui.demo -e command enter >/dev/null 2>&1
    am broadcast -a com.android.systemui.demo -e command network -e wifi hide >/dev/null 2>&1
    
    L=$(cat $ST_DIR/level 2>/dev/null || echo "4")
    T=$(cat $ST_DIR/type 2>/dev/null || echo "5g")
    N=$(cat $ST_DIR/name 2>/dev/null || echo "MineNet")
    
    # SIM 1 - Silenciada
    am broadcast -a com.android.systemui.demo -e command network -e slot 0 -e mobile show -e level $L -e datatype $T -e operator "$N" -e nosim false >/dev/null 2>&1
    
    # SIM 2 - Silenciada
    if [ -f "$ST_DIR/sim2_active" ]; then
        am broadcast -a com.android.systemui.demo -e command network -e slot 1 -e mobile show -e level $L -e datatype $T -e operator "$N" -e nosim false >/dev/null 2>&1
    fi
}

case $1 in
    -l) echo "$2" > $ST_DIR/level; actualizar ;;
    -t) echo "$2" > $ST_DIR/type; actualizar ;;
    -n) echo "$2" > $ST_DIR/name; actualizar ;;
    -s) 
        if [ "$2" = "2" ]; then touch $ST_DIR/sim2_active; else rm -f $ST_DIR/sim2_active; fi
        actualizar
        ;;
    -fix)
        settings put global sysui_demo_allowed 1 >/dev/null 2>&1
        actualizar
        ;;
    *)
        echo "Uso: minenet [-l nivel] [-t tipo] [-n nombre] [-s 1/2] [-fix]"
        ;;
esac
