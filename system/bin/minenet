#!/system/bin/sh
# minenet - Control de Red (Versión con Modo Satélite)
ST_DIR="/data/local/tmp/minenet"
mkdir -p $ST_DIR

if [ "$1" = "-h" ] || [ -z "$1" ]; then
    echo "Uso: minenet -t [tipo] -l [nivel]"
    echo "Tipos: 5g, g, 3g, lte, 1x, h, h+, s, lte, lte+, 5ge, 5g+"
    echo "Comando especial: minenet -s (Activa Satélite SOS - Solo Android 16+)"
    exit 0
fi

TYPE="5g"
LEVEL="4"

# Nuevo comando rápido para Satélite
if [ "$1" = "-s" ]; then
    TYPE="s"
    LEVEL="0"
else
    while [ "$1" != "" ]; do
        case $1 in
            -t | --type )   shift; TYPE=$1 ;;
            -l | --level )  shift; LEVEL=$1 ;;
        esac
        shift
    done
fi

# Guardar configuración
echo "$TYPE" > $ST_DIR/type
echo "$LEVEL" > $ST_DIR/level

# Feedback visual
case $TYPE in
    "s") echo "🛰️ MODO SATÉLITE SOS ACTIVADO (Solo Android 16)" ;;
    "g"|"1x"|"e") echo "⚠️ MODO TORTUGA ACTIVADO 🦖" ;;
    "3g"|"h"|"h+") echo "⏳ MODO VINTAGE ACTIVADO" ;;
    "lte"|"lte+"|"5ge") echo "↔️MODO INTERMEDIO ACTIVADO" ;;
    "5g+") echo "🚀🚀 MODO ULTRA VELOCIDAD ACTIVADO" ;;
    *) echo "🚀 MODO VELOCIDAD ACTIVADO" ;;

esac

echo "Icono: $TYPE | Señal: $LEVEL/4"