#!/system/bin/sh

ST_DIR="/data/local/tmp/minenet"
mkdir -p $ST_DIR

case $1 in
    -v|--volte)
        echo "$2" > $ST_DIR/volte
        echo "Icono VoLTE configurado en: $2 (true/false)"
        ;;
    -l|--level)
        echo "$2" > $ST_DIR/level
        echo "Señal fijada en: $2"
        ;;
    -t|--type)
        echo "$2" > $ST_DIR/type
        echo "Red fijada en: $2"
        ;;
    -h|--help)
        echo "=============================="
        echo "   MINENET COMMAND CENTER"
        echo "=============================="
        echo "  -v [true/false]  Mostrar/Ocultar VoLTE/Show/Hide VoLTE"
        echo "  -l [0-4]         Nivel de barras/bara level"
        echo "  -t [tipo]        Tipo/type (5g, 4g, etc)"
        echo "=============================="
        ;;
    *)
        echo "Comando no reconocido. Usa 'minenet -h'//Unrecognized command. Use 'minenet -h'"
        ;;
esac
