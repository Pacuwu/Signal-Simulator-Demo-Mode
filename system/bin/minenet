#!/system/bin/sh
# minenet - Control de Red (Versión Simplificada)
ST_DIR="/data/local/tmp/minenet"
mkdir -p $ST_DIR

if [ "$1" = "-h" ] || [ -z "$1" ]; then
    echo "Uso: minenet -t [tipo] -l [nivel]"
    echo "Tipos: 5g, 5ge, lte+, lte, h+, h, 3g, e, 1x, g"
    exit 0
fi

TYPE="5g"
LEVEL="4"

while [ "$1" != "" ]; do
    case $1 in
        -t | --type )   shift; TYPE=$1 ;;
        -l | --level )  shift; LEVEL=$1 ;;
    esac
    shift
done

# Guardar configuración
echo "$TYPE" > $ST_DIR/type
echo "$LEVEL" > $ST_DIR/level

# Feedback visual
case $TYPE in
    "g"|"1x"|"e") echo "⚠️ MODO TORTUGA ACTIVADO 🦖" ;;
    "3g"|"h"|"h+") echo "⏳ MODO VINTAGE ACTIVADO" ;;
    "lte+"|"lte"|"5ge"|"5g") echo "🚀 MODO VELOCIDAD ACTIVADO" ;;
esac